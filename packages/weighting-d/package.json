    "@audio/biquad": "^1.1.0"
  },
  "keywords": [
    "audio",
    "dsp",
    "weighting",
    "d"
  ],
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/weighting.git",
    "directory": "packages/weighting-d"
  },
  "funding": "https://github.com/sponsors/audiojs",
