{
  "name": "@audio/weighting-d",
  "version": "1.0.2",
  "description": "IEC 537 D-weighting filter — aircraft-noise frequency response (resonant hump near 4 kHz)",
  "type": "module",
  "sideEffects": false,
  "main": "d-weighting.js",
  "types": "./d-weighting.d.ts",
  "exports": {
