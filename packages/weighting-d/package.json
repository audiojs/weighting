    "./audio": {
      "types": "./audio.d.ts",
      "default": "./audio.js"
    }
  },
  "files": [
    "d-weighting.js",
    "d-weighting.d.ts",
    "audio.js",
    "audio.d.ts"
  ],
  "dependencies": {
