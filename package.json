{
  "name": "@audio/weighting",
  "version": "1.2.0",
  "type": "module",
  "sideEffects": false,
  "description": "Frequency weighting filters — umbrella for @audio/weighting-* atoms (A, B, C, D, K/BS.1770, ITU-R 468, RIAA)",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "node test.js",
    "test:all": "npm test --workspaces --if-present && npm test",
    "publish:all": "npm publish --workspaces && npm publish"
  },
  "dependencies": {
    "@audio/weighting-a": "^1.0.0",
    "@audio/weighting-c": "^1.0.0",
    "@audio/weighting-k": "^1.0.0",
    "@audio/weighting-itu468": "^1.0.0",
    "@audio/weighting-riaa": "^1.0.0",
    "@audio/weighting-b": "^1.0.0",
    "@audio/weighting-d": "^1.0.0"
  },
  "devDependencies": {
    "tst": "^9.4.0",
    "a-weighting": "^2.0.1"
  },
  "keywords": [
    "audio",
    "dsp",
    "weighting",
    "a-weighting",
    "k-weighting",
    "bs1770",
    "itu468",
    "riaa"
  ],
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/weighting.git"
  }
}
